{
	"Rules": [
		{
			"name": "Same parent species",
			"description": "Two parents with the same breeding id produce that same Pal before standard rank fallback; redundant same-species DT_PalCombiUnique rows are omitted from the data file."
		},
		{
			"name": "Game fixed combination",
			"description": "Rows listed in UniqueCombinations are non-same-species DT_PalCombiUnique fixed combinations that override standard rank fallback; rows with parent gender fields can produce gender-specific children."
		},
		{
			"name": "Standard rank fallback",
			"description": "For normal fallback combinations, calculate floor((parentA.breeding.rank + parentB.breeding.rank + 1) / 2), choose the standard-child Pal with the closest breeding rank, then break ties by higher breeding priority and then non-variant status."
		},
		{
			"name": "Source override",
			"description": "Optional SourceOverrides rows are only written when verified external corrections cannot be represented by local game-file ranks, standard-child flags, and fixed combinations."
		}
	],
