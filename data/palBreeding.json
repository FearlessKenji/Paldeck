	"Rules": [
		{
			"name": "Same parent species",
			"description": "Two parents with the same breedingId produce that same Pal before special combinations or rank calculation are applied."
		},
		{
			"name": "Special combination override",
			"description": "Pairs listed in SpecialCombinations produce the listed child regardless of breedingRank."
		},
		{
			"name": "Standard rank result",
			"description": "For normal combinations, calculate floor((parentA.breedingRank + parentB.breedingRank + 1) / 2), then choose the canBeStandardChild Pal with the closest breedingRank."
		},
		{
			"name": "Standard result tie breaker",
			"description": "If two eligible Pals are equally close to the target rank, the earlier Pal in Pals order wins."
		}
	],
