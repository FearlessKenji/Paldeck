{
  "name": "paldeck",
  "version": "1.3.0",
  "private": true,
  "license": "GPL-3.0-only",
  "scripts": {
    "start": "node index.js",
    "deploy:global": "node deploy-global-commands.js",
    "deploy:guild": "node deploy-guild-commands.js",
    "commands:clear": "node delete-all-commands.js",
    "db:init": "node database/dbInit.js",
    "db:reset": "node database/dbInit.js --force",
    "audit:palworld-data": "node scripts/audit-palworld-data.js",
    "audit:palworld-data:summary": "node scripts/audit-palworld-data.js --limit 0",
    "audit:palworld-data:json": "node scripts/audit-palworld-data.js --json",
    "audit:palworld-data:ci": "node scripts/audit-palworld-data.js --fail-on-drift",
    "audit:palworld-breeding-results": "node scripts/audit-palworld-breeding-results.js",
    "audit:palworld-breeding-results:full": "node scripts/audit-palworld-breeding-results.js --full",
    "update:palworld-data": "node scripts/update-palworld-data.js",
    "update:palworld-data:write": "node scripts/update-palworld-data.js --write",
    "add:missing-paldata": "node scripts/add-missing-paldata-entries.js",
    "add:missing-paldata:write": "node scripts/add-missing-paldata-entries.js --write",
    "update:palworld-breeding-results": "node scripts/update-palworld-breeding-results.js",
    "update:palworld-breeding-results:write": "node scripts/update-palworld-breeding-results.js --write",
    "update:palworld-items": "node scripts/update-palworld-items.js",
    "update:palworld-items:write": "node scripts/update-palworld-items.js --write",
    "validate:pal-data": "node scripts/validate-pal-data.js",
    "validate:item-data": "node scripts/validate-item-data.js",
    "lint": "node scripts/lint.js",
    "smoke": "node scripts/smokeTest.js",
    "pm2:start": "pm2 start config/ecosystem.config.js"
  },
  "dependencies": {
    "cron": "^3.1.6",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "sequelize": "^6.37.3",
    "sqlite3": "^6.0.1",
    "tar": "^7.5.16"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "overrides": {
    "undici": "6.27.0",
    "sequelize": {
      "uuid": "^11.1.1"
    }
  }
}
